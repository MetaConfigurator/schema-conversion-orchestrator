    rdfs:comment "The preferred namespace URI to use when using terms from this vocabulary in an XML document."@en ;
    rdfs:isDefinedBy <http://purl.org/vocab/vann> .

<http://schema.org/ComicCoverArt>
    a owl:Class ;
    rdfs:isDefinedBy <http://bib.schema.org> ;
    rdfs:subClassOf <http://schema.org/ComicStory>, <http://schema.org/CoverArt> .

<http://schema.org/ComicIssue>
    a owl:Class ;
    rdfs:isDefinedBy <http://bib.schema.org> ;
    rdfs:subClassOf <http://schema.org/PublicationIssue> .

<http://schema.org/ComicSeries>
    a owl:Class ;
    rdfs:isDefinedBy <http://bib.schema.org> ;
    rdfs:subClassOf <http://schema.org/Periodical> .

<http://schema.org/ComicStory>
    a owl:Class ;
    rdfs:isDefinedBy <http://bib.schema.org> ;
    rdfs:subClassOf <http://schema.org/CreativeWork> .

<http://schema.org/CoverArt>
    a owl:Class ;
    rdfs:isDefinedBy <http://bib.schema.org> ;
    rdfs:subClassOf <http://schema.org/VisualArtwork> .

<http://schema.org/CreativeWork>
    :qlabel "schema:CreativeWork" ;
    a owl:Class ;
    rdfs:isDefinedBy <http://schema.org> .

<http://schema.org/IndividualProduct>
    :qlabel "schema:IndividualProduct" ;
    a owl:Class ;
    rdfs:isDefinedBy <http://schema.org> ;
    rdfs:subClassOf <http://schema.org/Product> .

<http://schema.org/Intangible>
    :qlabel "schema:Intangible" ;
    a owl:Class ;
    rdfs:isDefinedBy <http://schema.org> .

<http://schema.org/Organization>
    :qlabel "schema:Organization" ;
    a owl:Class ;
    rdfs:comment "An organization."@en ;
    rdfs:isDefinedBy <http://schema.org> ;
    rdfs:subClassOf foaf:Agent .

<http://schema.org/Periodical>
    :qlabel "schema:Periodical" ;
    a owl:Class ;
    rdfs:isDefinedBy <http://schema.org> ;
    rdfs:subClassOf <http://schema.org/CreativeWork> .

<http://schema.org/Person>
    :qlabel "schema:Person" ;
    a owl:Class ;
    rdfs:comment "A person."@en ;
    rdfs:isDefinedBy <http://schema.org> ;
    rdfs:subClassOf foaf:Agent .

<http://schema.org/Product>
    :qlabel "schema:Product" ;
    a owl:Class ;
    rdfs:isDefinedBy <http://schema.org> .

<http://schema.org/PublicationIssue>
    :qlabel "schema:PublicationIssue" ;
    a owl:Class ;
    rdfs:isDefinedBy <http://schema.org> ;
    rdfs:subClassOf <http://schema.org/CreativeWork> .

<http://schema.org/PublicationVolume>
    :qlabel "schema:PublicationVolume" ;
    a owl:Class ;
    rdfs:isDefinedBy <http://schema.org> ;
    rdfs:subClassOf <http://schema.org/CreativeWork> .

<http://schema.org/VisualArtwork>
    a owl:Class ;
    rdfs:isDefinedBy <http://schema.org> ;
    rdfs:subClassOf <http://schema.org/CreativeWork> .

<http://schema.org/contributor>
    dc:description "Used to associate a contributor with any creative work."@en ;
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <http://schema.org> .

<http://schema.org/creator>
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <http://schema.org> .

<http://schema.org/isbn>
    a owl:DatatypeProperty ;
    rdfs:isDefinedBy <http://schema.org> ;
    rdfs:range rdfs:Literal .

<http://schema.org/issn>
    a owl:DatatypeProperty ;
    rdfs:domain <http://schema.org/Periodical> ;
    rdfs:isDefinedBy <http://schema.org> ;
    rdfs:range rdfs:Literal .

<http://schema.org/name>
    dc:description "Used to describe the name of an agent."@en ;
    a owl:DatatypeProperty ;
    rdfs:comment "A name."@en ;
    rdfs:domain foaf:Agent ;
    rdfs:isDefinedBy <http://schema.org> ;
    rdfs:range rdfs:Literal .

<http://schema.org/publisher>
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <http://schema.org> .

<http://schema.org/sku>
    dc:description "The SKU of a comics product."@en ;
    a owl:DatatypeProperty ;
    rdfs:domain <http://schema.org/Product> ;
    rdfs:isDefinedBy <http://schema.org> ;
    rdfs:label "SKU"@en ;
    rdfs:range rdfs:Literal .

<http://schema.org/url>
    dc:description "Used to indicate web content related to a resource."@en ;
    a owl:DatatypeProperty ;
