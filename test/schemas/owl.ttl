:variant
    a owl:ObjectProperty ;
    rdfs:comment "Links a comic issue to a variant."@en ;
    rdfs:domain :Issue ;
    rdfs:label "variant"@en ;
    rdfs:range :Issue ;
    rdfs:subPropertyOf dcterms:hasVersion ;
    owl:inverseOf :variantOf ;
    vs:term_status "unstable"@en .

:variantOf
    a owl:ObjectProperty ;
    rdfs:comment "Links a comic issue to the issue it is a variant of."@en ;
    rdfs:domain :Issue ;
    rdfs:label "variant of"@en ;
    rdfs:range :Issue ;
    rdfs:subPropertyOf dcterms:isVersionOf ;
    vs:term_status "unstable" .

:volume
    a owl:ObjectProperty ;
    rdfs:comment "Links a series to a comic volume."@en ;
    rdfs:domain :Series ;
    rdfs:label "volume"@en ;
    rdfs:range :Volume ;
    rdfs:subPropertyOf dcterms:hasPart ;
    owl:inverseOf :volumeOf ;
    vs:term_status "unstable" .

:volumeNumber
    a owl:DatatypeProperty ;
    rdfs:comment "The unique identifier of a comic volume."@en ;
    rdfs:domain :Volume ;
    rdfs:label "volumeNumber"@en ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf dcterms:identifier ;
    vs:term_status "testing" .

:volumeOf
    a owl:ObjectProperty ;
    rdfs:comment "Links a volume to a comic series."@en ;
    rdfs:domain :Volume ;
    rdfs:label "volume of"@en ;
    rdfs:range :Series ;
    rdfs:subPropertyOf dcterms:isPartOf ;
    vs:term_status "unstable" .

:writer
    a owl:ObjectProperty ;
    rdfs:comment "Associates a writer with a comic work."@en ;
    rdfs:domain :Comic ;
    rdfs:label "writer"@en ;
    rdfs:range :Contributor ;
    rdfs:subPropertyOf :contributor ;
    vs:term_status "unstable" .

