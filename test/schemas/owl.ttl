@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix : <http://comicmeta.org/cbo/> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix cbv: <http://comicmeta.org/vocab/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix xsp: <http://www.owl-ontologies.com/2005/08/07/xsp.owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix dctype: <http://purl.org/dc/dcmitype/> .
@prefix schema: <http://schema.org> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix protege: <http://protege.stanford.edu/plugins/owl/protege#> .

<http://comicmeta.org/cbo/>
    dc:creator <https://sean.petiya.com/#me> ;
    dc:description "An OWL ontology and RDF metadata vocabulary for describing comic books and comic book collections." ;
    dc:title "Comic Book Ontology"@en ;
    dcterms:license <http://creativecommons.org/licenses/by/4.0> ;
    dcterms:modified "2023-03-15" ;
    vann:preferredNamespacePrefix "cbo" ;
    vann:preferredNamespaceUri "http://comicmeta.org/cbo/" ;
    a owl:Ontology ;
    owl:versionIRI <http://comicmeta.org/cbo/> ;
    owl:versionInfo "0.16.0" .

:Agent
    a owl:Class ;
    rdfs:comment "A person, organization, or intelligence in a comic universe."@en ;
    rdfs:label "Agent" ;
    rdfs:subClassOf :Thing ;
    vs:term_status "unstable" .

:Artwork
    a owl:Class ;
    rdfs:comment "Original comic artwork."@en ;
    rdfs:label "Artwork"@en ;
    rdfs:subClassOf :Item, <http://schema.org/IndividualProduct> ;
    vs:term_status "unstable" .

:Balloon
    a owl:Class ;
    rdfs:comment "A word balloon in a comics sequence containing dialogue, thought, or sound."@en ;
    rdfs:label "Balloon"@en ;
    rdfs:seeAlso "http://dcl.slis.indiana.edu/cbml/schema/cbml.html#TEI.balloon" ;
    rdfs:subClassOf :Sequence ;
    vs:term_status "unstable" .

:Binding
    a owl:Class ;
    rdfs:comment "A binding method or material used to bind the pages of a comic."@en ;
    rdfs:label "Binding"@en ;
    rdfs:subClassOf :Material ;
    vs:term_status "unstable" .

:Box
    a owl:Class ;
    rdfs:comment "A box that contains comic books."@en ;
    rdfs:label "Box"@en ;
    rdfs:subClassOf :Container ;
    vs:term_status "unstable" .

:Building
    a owl:Class ;
    rdfs:comment "A building in a comic universe."@en ;
    rdfs:label "Building"@en ;
    rdfs:subClassOf :Object ;
    vs:term_status "unstable"@en .

:Caption
    a owl:Class ;
    rdfs:comment "A caption containing narration in a comics sequence."@en ;
    rdfs:label "Caption"@en ;
    rdfs:seeAlso "http://dcl.slis.indiana.edu/cbml/schema/cbml.html#TEI.caption" ;
    rdfs:subClassOf :Sequence ;
    vs:term_status "unstable" .

:Character
    a owl:Class ;
    rdfs:comment "A comic character."@en ;
    rdfs:label "Character"@en ;
    rdfs:subClassOf :Agent ;
    vs:term_status "unstable" .

:Collection
    a owl:Class ;
    rdfs:comment "A collection of comic books and related resources."@en ;
    rdfs:label "Collection"@en ;
    rdfs:subClassOf dctype:Collection ;
    vs:term_status "unstable" .

:Collector
    a owl:Class ;
    rdfs:comment "A comic book collector."@en ;
    rdfs:label "Collector"@en ;
    rdfs:subClassOf <http://schema.org/Person> ;
    vs:term_status "unstable" .

:Comic
    a owl:Class ;
    rdfs:comment "A creative work of sequential art: the juxtaposition of text, images, and other pictorial elements to communicate information."@en ;
    rdfs:label "Comic"@en ;
    rdfs:subClassOf <http://schema.org/CreativeWork> ;
    vs:term_status "testing" .

:ComicAge
    a owl:Class ;
    rdfs:comment "A period of comic book history."@en ;
    rdfs:label "Comic Age"@en ;
    rdfs:subClassOf <http://schema.org/Intangible> ;
    vs:term_status "unstable" .

:ComicUniverse
    a owl:Class ;
    rdfs:comment "A comic universe."@en ;
    rdfs:label "Comic Universe"@en ;
    rdfs:subClassOf <http://schema.org/CreativeWork> ;
    vs:term_status "unstable" .

:Condition
    a owl:Class ;
    rdfs:comment "A physical condition describing an object."@en ;
    rdfs:label "Condition"@en ;
    rdfs:subClassOf :PhysicalAttribute ;
    vs:term_status "unstable" .

:Container
    a owl:Class ;
    rdfs:comment "An object containing comic books."@en ;
    rdfs:label "Container"@en ;
    rdfs:subClassOf dctype:PhysicalObject ;
    vs:term_status "unstable" .

:Contributor
    a owl:Class ;
    rdfs:comment "An agent contributing to the creation of a comic work."@en ;
    rdfs:label "Contributor"@en ;
    rdfs:subClassOf <http://schema.org/Person> ;
    vs:term_status "unstable" .

:Copy
    a owl:Class ;
    rdfs:comment "A copy of a comic issue."@en ;
    rdfs:label "Copy"@en ;
    rdfs:subClassOf :Issue, :Item, <http://schema.org/IndividualProduct> ;
    vs:term_status "unstable" .

:Costume
    a owl:Class ;
    rdfs:comment "A comic character's costume."@en ;
    rdfs:label "Costume"@en ;
    rdfs:subClassOf :Object ;
    vs:term_status "unstable" .

:Creator
    a owl:Class ;
    rdfs:comment "An agent primarily responsible for the creation of a comic work."@en ;
    rdfs:label "Creator"@en ;
    rdfs:subClassOf <http://schema.org/Person> ;
    vs:term_status "unstable" .

:Distributor
    a owl:Class ;
    rdfs:comment "An agent responsible for the distribution of a comic publication."@en ;
    rdfs:label "Distributor" ;
    rdfs:subClassOf <http://schema.org/Organization> ;
    vs:term_status "unstable" .

:Document
    a owl:Class ;
    rdfs:comment "A document composed of the pages in a comics publication."@en ;
    rdfs:label "Document"@en ;
    rdfs:subClassOf :Comic ;
    owl:deprecated true ;
    vs:term_status "deprecated" .

:Edition
    a owl:Class ;
    rdfs:comment "An edition of a comic issue."@en ;
    rdfs:label "Edition"@en ;
    rdfs:subClassOf <http://schema.org/Intangible> ;
    vs:term_status "unstable" .

:Event
    a owl:Class ;
    rdfs:comment "An event in a comic universe."@en ;
    rdfs:label "Event"@en ;
    rdfs:subClassOf :Thing ;
    vs:term_status "unstable" .

:Format
    a owl:Class ;
    rdfs:comment "A format in which a comic is embodied."@en ;
    rdfs:label "Format"@en ;
    rdfs:subClassOf <http://schema.org/Intangible> ;
    vs:term_status "unstable" .

:Frequency
    a owl:Class ;
    rdfs:comment "A frequency with which a comic is published."@en ;
    rdfs:label "Frequency"@en ;
    rdfs:subClassOf <http://schema.org/Intangible> ;
    vs:term_status "unstable" .

:Genre
    a owl:Class ;
    rdfs:comment "A comics genre."@en ;
    rdfs:label "Genre"@en ;
    rdfs:subClassOf <http://schema.org/Intangible> ;
    vs:term_status "unstable" .

:Grade
    a owl:Class ;
    rdfs:comment "A grade assigned to a comic item that represents a summary of its condition."@en ;
    rdfs:label "Grade"@en ;
    rdfs:subClassOf <http://schema.org/Intangible> ;
    vs:term_status "unstable" .

:Guarantor
    a owl:Class ;
    rdfs:comment "An organization that guarantees the stated condition of a comic book."@en ;
    rdfs:label "Guarantor"@en ;
    rdfs:subClassOf <http://schema.org/Organization> ;
    vs:term_status "unstable" .

:Gutter
    a owl:Class ;
    rdfs:comment "The space between panels in a comics sequence."@en ;
    rdfs:label "Gutter"@en ;
    rdfs:subClassOf :Sequence ;
    vs:term_status "unstable" .

:Imprint
    a owl:Class ;
    rdfs:comment "An imprint or tradename of a comic publisher."@en ;
    rdfs:label "Imprint"@en ;
    rdfs:subClassOf :Publisher ;
    vs:term_status "unstable" .

:Issue
    a owl:Class ;
    rdfs:comment "An issue of a comic publication."@en ;
    rdfs:label "Issue"@en ;
    rdfs:subClassOf :Publication, <http://schema.org/Product>, <http://schema.org/PublicationIssue> ;
    owl:equivalentClass <http://schema.org/ComicIssue> ;
    vs:term_status "unstable" .

:Item
    a owl:Class ;
    rdfs:comment "A physical or digital item."@en ;
    rdfs:label "Item" ;
    vs:term_status "unstable" .

:Library
    a owl:Class ;
    rdfs:comment "A physical or digital library containing a collection of comic resources."@en ;
    rdfs:label "Library" ;
    rdfs:subClassOf <http://schema.org/Organization> ;
    vs:term_status "unstable" .

:Location
    a owl:Class ;
    rdfs:comment "A location in a comic universe."@en ;
    rdfs:label "Location"@en ;
    rdfs:subClassOf :Thing ;
    vs:term_status "unstable" .

:Material
    a owl:Class ;
    rdfs:comment "A material or medium of which an object is composed."@en ;
    rdfs:label "Material" ;
    rdfs:subClassOf :PhysicalAttribute ;
    vs:term_status "unstable" .

:Museum
    a owl:Class ;
    rdfs:comment "A physical or digital museum exhibiting a collection of comic resources."@en ;
    rdfs:label "Museum"@en ;
    rdfs:subClassOf <http://schema.org/Organization> ;
    vs:term_status "unstable" .

:Object
    a owl:Class ;
    rdfs:comment "An object in a comic universe."@en ;
    rdfs:label "Object"@en ;
    rdfs:subClassOf :Thing ;
    vs:term_status "unstable" .

:Page
    a owl:Class ;
    rdfs:comment "A page in a comics sequence."@en ;
    rdfs:label "Page"@en ;
    rdfs:subClassOf :Sequence ;
    vs:term_status "unstable" .

:PageType
    a owl:Class ;
    rdfs:comment "A type of page appearing in a comic document."@en ;
    rdfs:label "Page Type"@en ;
    rdfs:subClassOf <http://schema.org/Intangible> ;
    vs:term_status "unstable" .

:Panel
    a owl:Class ;
    rdfs:comment "A visual frame containing part of a comics sequence."@en ;
    rdfs:label "Panel"@en ;
    rdfs:seeAlso "http://dcl.slis.indiana.edu/cbml/schema/cbml.html#TEI.panel" ;
    rdfs:subClassOf :Sequence ;
    vs:term_status "unstable" .

:Paper
    a owl:Class ;
    rdfs:comment "A paper stock on which a comic is printed."@en ;
    rdfs:label "Paper"@en ;
    rdfs:subClassOf :Material ;
    vs:term_status "unstable" .

:Pedigree
    a owl:Class ;
    rdfs:comment "An exceptional original owner collection of high quality, vintage comic books often containing copies that are considered exemplars of key issues."@en ;
    rdfs:label "Pedigree"@en ;
    rdfs:subClassOf :Collection ;
    vs:term_status "unstable" .

:PhysicalAttribute
    a owl:Class ;
    rdfs:comment "An physical attribute or property of an item."@en ;
    rdfs:label "Attribute"@en ;
    vs:term_status "unstable" .

:Planet
    a owl:Class ;
    rdfs:comment "A planetary body in a comic universe."@en ;
    rdfs:label "Planet"@en ;
    rdfs:subClassOf :Location ;
    vs:term_status "unstable" .

:Plastic
    a owl:Class ;
    rdfs:comment "A plastic of which a supply item is composed."@en ;
    rdfs:label "Plastic"@en ;
    rdfs:subClassOf :Material ;
    vs:term_status "unstable" .

:Publication
    a owl:Class ;
    rdfs:comment "A comics publication."@en ;
    rdfs:label "Publication"@en ;
    rdfs:subClassOf :Comic ;
    vs:term_status "unstable" .

:Publisher
    a owl:Class ;
    rdfs:comment "An agent responsible for the publication of a comic."@en ;
    rdfs:label "Publisher"@en ;
    rdfs:subClassOf <http://schema.org/Organization> ;
    vs:term_status "unstable" .

:Quality
    a owl:Class ;
    rdfs:comment "A distinctive quality belonging to an object."@en ;
    rdfs:label "Quality" ;
    rdfs:subClassOf :PhysicalAttribute ;
    vs:term_status "unstable" .

:Role
    a owl:Class ;
    rdfs:comment "A creative role in the production of a comic work."@en ;
    rdfs:label "Role"@en ;
    rdfs:subClassOf <http://schema.org/Intangible> ;
    vs:term_status "unstable" .

:Sequence
    a owl:Class ;
    rdfs:comment "A sequence of juxtaposed panels, text, and other pictorial elements."@en ;
    rdfs:label "Sequence"@en ;
    rdfs:subClassOf :Comic ;
    vs:term_status "unstable" .

:Series
    a owl:Class ;
    rdfs:comment "A comic publication containing one or more volumes and issues."@en ;
    rdfs:label "Series"@en ;
    rdfs:subClassOf :Publication, <http://schema.org/Periodical> ;
    owl:equivalentClass <http://schema.org/ComicSeries> ;
    vs:term_status "unstable" .

:State
    a owl:Class ;
    rdfs:comment "A physical state describing an object."@en ;
    rdfs:label "State"@en ;
    rdfs:subClassOf :PhysicalAttribute ;
    vs:term_status "unstable" .

:Story
    a owl:Class ;
    rdfs:comment "A comics story."@en ;
    rdfs:label "Story"@en ;
    rdfs:subClassOf :Sequence ;
    owl:equivalentClass <http://schema.org/ComicStory> ;
    vs:term_status "unstable" .

:Team
    a owl:Class ;
    rdfs:comment "A group of comic characters."@en ;
    rdfs:label "Team" ;
    rdfs:subClassOf :Agent ;
    vs:term_status "unstable" .

:Thing
    a owl:Class ;
    rdfs:comment "A thing in a comic universe."@en ;
    rdfs:label "Thing" ;
    rdfs:subClassOf :ComicUniverse ;
    vs:term_status "unstable" .

:Vehicle
    a owl:Class ;
    rdfs:comment "A vehicle in a comic universe." ;
    rdfs:label "Vehicle" ;
    rdfs:subClassOf :Object ;
    vs:term_status "unstable" .

:Volume
    a owl:Class ;
    rdfs:comment "A single issue or group of issues published in a comic series."@en ;
    rdfs:label "Volume"@en ;
    rdfs:subClassOf :Publication, <http://schema.org/PublicationVolume> ;
    vs:term_status "unstable" .

:adaptation
    a owl:ObjectProperty ;
    rdfs:comment "Links a comic to an adaptation."@en ;
    rdfs:domain :Comic ;
    rdfs:label "adaptation"@en ;
    rdfs:range <http://schema.org/CreativeWork> ;
    rdfs:subPropertyOf dcterms:hasVersion ;
    owl:inverseOf :adaptationOf ;
    vs:term_status "unstable" .

:adaptationOf
    a owl:ObjectProperty ;
    rdfs:comment "Links a work to the comic work it is an adaptation of."@en ;
    rdfs:domain :Comic ;
    rdfs:label "adaptation of"@en ;
    rdfs:range :Comic ;
    rdfs:subPropertyOf dcterms:isVersionOf ;
    vs:term_status "unstable" .

:alternativeTitle
    a owl:DatatypeProperty ;
    rdfs:comment "An alternative title for any comic work."@en ;
    rdfs:domain :Comic ;
    rdfs:label "alternative title"@en ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf dcterms:alternative ;
    vs:term_status "unstable" .

:appearance
    a owl:ObjectProperty ;
    rdfs:comment "Describes the appearance of a comic universe element within a comic work."@en ;
    rdfs:domain :Comic ;
    rdfs:label "appearance"@en ;
    rdfs:range :Thing ;
    vs:term_status "unstable" .

:artist
    a owl:ObjectProperty ;
    rdfs:comment "Associates an artist with a comic work."@en ;
    rdfs:domain :Comic ;
    rdfs:label "artist"@en ;
    rdfs:range :Contributor ;
    rdfs:subPropertyOf :contributor ;
    vs:term_status "unstable" .

:artwork
    a owl:ObjectProperty ;
    rdfs:comment "Links a comic page to its original artwork."@en ;
    rdfs:domain :Page ;
    rdfs:label "artwork"@en ;
    rdfs:range :Artwork ;
    owl:inverseOf :artworkOf ;
    vs:term_status "unstable" .

:artworkOf
    a owl:ObjectProperty ;
    rdfs:comment "Links orginal comic artwork to a page."@en ;
    rdfs:domain :Artwork ;
    rdfs:label "artwork of"@en ;
    rdfs:range :Page ;
    vs:term_status "unstable" .

:artworkType
    a owl:ObjectProperty ;
    rdfs:comment "Describes the artwork type of one or more pages of comic art."@en ;
    rdfs:label "artwork type"@en ;
    vs:term_status "unstable" .

:attribute
    a owl:ObjectProperty ;
    rdfs:comment "Describes a physical attribute of a comic item."@en ;
    rdfs:domain dctype:PhysicalObject ;
    rdfs:label "attribute"@en ;
    rdfs:range :PhysicalAttribute ;
    vs:term_status "unstable" .

:bagged
    dc:description "Having this property implies that the comic is bagged."@en ;
    a owl:ObjectProperty ;
    rdfs:comment "Describes the bag in which a comic is contained."@en ;
    rdfs:domain :Copy ;
    rdfs:label "bagged"@en ;
    rdfs:range :Material ;
    rdfs:subPropertyOf :attribute ;
    vs:term_status "unstable" .

:balloon
    a owl:ObjectProperty ;
    rdfs:comment "Links a panel to a comics sequence."@en ;
    rdfs:domain :Sequence ;
    rdfs:label "balloon"@en ;
    rdfs:range :Balloon ;
    rdfs:subPropertyOf :sequence ;
    vs:term_status "unstable" .

:binding
    a owl:ObjectProperty ;
    rdfs:comment "Describes the binding of a comic issue."@en ;
    rdfs:domain :Issue ;
    rdfs:label "binding"@en ;
    rdfs:range :Binding ;
    rdfs:subPropertyOf :material ;
    vs:term_status "unstable" .

:boarded
    dc:description "Having this property implies that the comic is boarded."@en ;
    a owl:ObjectProperty ;
    rdfs:comment "Describes the backing board of a comic."@en ;
    rdfs:domain :Copy ;
    rdfs:label "boarded"@en ;
    rdfs:range :Material ;
    rdfs:subPropertyOf :attribute ;
    vs:term_status "unstable" .

:box
    a owl:ObjectProperty ;
    rdfs:comment "Associates a box with a comic book collection."@en ;
    rdfs:domain :Collection ;
    rdfs:label "box"@en ;
    rdfs:range :Box ;
    rdfs:subPropertyOf dcterms:hasPart ;
    vs:term_status "unstable" .

:cameo
    a owl:ObjectProperty ;
    rdfs:comment "Describes a cameo appearance by a comic character in a comic work."@en ;
    rdfs:domain :Comic ;
    rdfs:label "cameo"@en ;
    rdfs:range :Character ;
    rdfs:subPropertyOf :character ;
    vs:term_status "unstable" .

:caption
    a owl:ObjectProperty ;
    rdfs:comment "Links a caption to a comics sequence."@en ;
    rdfs:domain :Sequence ;
    rdfs:label "caption"@en ;
    rdfs:range :Caption ;
    rdfs:subPropertyOf :sequence ;
    vs:term_status "unstable" .

:category
    a owl:AnnotationProperty .

:cca
    a owl:DatatypeProperty ;
    rdfs:comment "Comics Code Authority (CCA) approved."@en ;
    rdfs:domain :Issue ;
    rdfs:label "CCA" ;
    rdfs:range xsd:boolean ;
    vs:term_status "unstable" .

:certNumber
    a owl:DatatypeProperty ;
    rdfs:comment "The certification number assigned to a graded copy of a comic by a guarantor."@en ;
    rdfs:domain :Copy ;
    rdfs:label "certification number"@en ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf dcterms:identifier ;
    vs:term_status "unstable" .

:character
    a owl:ObjectProperty ;
    rdfs:comment "Describes the appearance of a comic character in a comic work."@en ;
    rdfs:domain :Comic ;
    rdfs:label "character"@en ;
    rdfs:range :Character ;
    rdfs:subPropertyOf :appearance ;
    vs:term_status "unstable" .

:collectedIn
    a owl:ObjectProperty ;
    rdfs:comment "Links a comic work to another work that reprints it as part of a comprehensive collection of reprinted material."@en ;
    rdfs:domain :Issue ;
    rdfs:label "collected in"@en ;
    rdfs:range :Issue ;
    rdfs:subPropertyOf :reprintedIn ;
    owl:inverseOf :collects ;
    vs:term_status "unstable" .

:collection
    a owl:ObjectProperty ;
    rdfs:comment "Links a collector to a collection."@en ;
    rdfs:domain :Collector ;
    rdfs:label "collection"@en ;
    rdfs:range :Collection ;
    vs:term_status "unstable" .

:collects
    a owl:ObjectProperty ;
    rdfs:comment "Links a comic issue to another work that reprints it as part of a comprehensive collection of reprinted material."@en ;
    rdfs:domain :Issue ;
    rdfs:label "collects" ;
    rdfs:range :Issue ;
    rdfs:subPropertyOf :reprints, dcterms:hasPart ;
    vs:term_status "unstable" .

:colorist
    a owl:ObjectProperty ;
    rdfs:comment "Associates a colorist with a comic work."@en ;
    rdfs:domain :Comic ;
    rdfs:label "colorist"@en ;
    rdfs:range :Contributor ;
    rdfs:subPropertyOf :contributor ;
    vs:term_status "unstable" .

:comicAge
    a owl:ObjectProperty ;
    rdfs:comment "Associates a comic with an era of comic book history."@en ;
    rdfs:domain :Comic ;
    rdfs:label "comic age"@en ;
    rdfs:range :ComicAge ;
    vs:term_status "unstable"@en .

:condition
    a owl:ObjectProperty ;
    rdfs:comment "Describes the physical condition of a comic item."@en ;
    rdfs:domain :Copy ;
    rdfs:label "condition"@en ;
    rdfs:range :Condition ;
    vs:term_status "unstable" .

:contains
    a owl:ObjectProperty ;
    rdfs:comment "Describes the contents of a box of comics."@en ;
    rdfs:domain :Container ;
    rdfs:label "contains"@en ;
    rdfs:range :Copy ;
    owl:inverseOf :inBox ;
    vs:term_status "unstable" .

:contributor
    a owl:ObjectProperty ;
    rdfs:comment "Associates a contributor with a comic work."@en ;
    rdfs:domain :Comic ;
    rdfs:label "contributor"@en ;
    rdfs:range :Contributor ;
    rdfs:subPropertyOf <http://schema.org/contributor> ;
    vs:term_status "unstable" .

:copy
    a owl:ObjectProperty ;
    rdfs:comment "Links a comic issue to a specific copy."@en ;
    rdfs:domain :Issue ;
    rdfs:label "copy"@en ;
    rdfs:range :Copy ;
    owl:inverseOf :copyOf ;
    vs:term_status "unstable" .

:copyOf
    a owl:ObjectProperty ;
    rdfs:comment "Links a specific copy to a comic issue."@en ;
    rdfs:domain :Copy ;
    rdfs:label "copy of"@en ;
    rdfs:range :Issue ;
    vs:term_status "unstable" .

:copyState
    a owl:ObjectProperty ;
    rdfs:comment "Describes the physical state of a copy of a comic issue."@en ;
    rdfs:domain :Copy ;
    rdfs:label "copy state"@en ;
    rdfs:range :State ;
    vs:term_status "unstable" .

:copyrightDate
    a owl:DatatypeProperty ;
    rdfs:comment "The copyright date of a comic issue."@en ;
    rdfs:domain :Issue ;
    rdfs:label "copyright date"@en ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf dcterms:date ;
    vs:term_status "unstable" .

:country
    a owl:ObjectProperty ;
    rdfs:comment "Links a comic series to its country of origin."@en ;
    rdfs:domain :Series ;
    rdfs:label "country"@en ;
    rdfs:range owl:Thing ;
    vs:term_status "unstable" .

:coverArt
    a owl:ObjectProperty ;
