{
  "type": "module",
  "name": "schema-converter-node",
  "version": "1.0.0",
  "description": "Node.js schema conversion service",
  "main": "converter.js",
  "bin": "dist/index.js",
  "pkg": {
    "scripts": "dist/**/*.js",
    "targets": [
      "node18-macos-x64",
      "node18-linux-x64",
      "node18-win-x64"
    ]
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "clean": "rm -rf *.js *.js.map dist/*.js dist/*.js.map"
  },
  "keywords": [
    "schema",
    "conversion",
    "json-schema",
    "xsd",
    "shacl",
    "dtd"
  ],
  "author": "Felix Neubauer",
  "license": "MIT",
  "devDependencies": {
    "@types/n3": "^1.26.0",
    "@types/node": "^24.5.2",
    "@types/rdf-ext": "^2.5.2",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "files": [
    "converter.js",
    "dataStructures.js",
    "src/converters/*.js"
  ],
  "dependencies": {
    "@comake/shacl-to-json-schema": "^1.0.3",
    "@frogcat/ttl2jsonld": "^0.0.10",
    "jsonld": "^8.3.3",
    "n3": "^1.26.0",
    "rdf-ext": "^2.6.0",
    "rdf-parse": "^4.0.0",
    "shacl-bridge": "^1.7.1",
    "shacl-jsonschema-converter": "^0.1.3",
    "xsd-json-converter": "^2.1.1",
    "xsd2jsonschema": "^0.3.7"
  }
}
